/// Create trained biases for 2-layer network (26 biases)
/// Trained biases from initial_weights_mlp.json
pub unconstrained fn create_trained_biases() -> [Field; 26] {
    [
        247, 253, 253, 248, 250, 254, 248, 250, -22, 253, 255, 249, 233, 255, -58, -24, 254, 246,
        255, 255, 255, 255, 255, 255, 254, 253,
    ]
}

/// Helper function to create test biases array (26 biases for 2-layer network)
pub unconstrained fn create_test_biases() -> [Field; 26] {
    let mut biases: [Field; 26] = [0; 26];
    for i in 0..26 {
        biases[i] = (i as Field) * 10000;
    }
    biases
}

/// Helper function to create test input pixels (64 pixels)
pub unconstrained fn create_test_input() -> [Field; 64] {
    let mut input: [Field; 64] = [0; 64];
    for i in 0..64 {
        input[i] = (i as Field) * 100000;
    }
    input
}

/// Helper function to create small test input pixels (64 pixels) for pure unit tests
pub unconstrained fn create_small_test_input() -> [Field; 64] {
    let mut input: [Field; 64] = [0; 64];
    for i in 0..64 {
        input[i] = (i as Field) * 1_000;
    }
    input
}

/// Helper function to create test weights (1184 weights) for pure unit tests
pub unconstrained fn create_small_test_weights() -> [Field; 1184] {
    let mut weights: [Field; 1184] = [0; 1184];
    for i in 0..1184 {
        weights[i] = (i as Field) * 10;
    }
    weights
}

/// Helper function to create test biases (26 biases) for pure unit tests
pub unconstrained fn create_small_test_biases() -> [Field; 26] {
    let mut biases: [Field; 26] = [0; 26];
    for i in 0..26 {
        biases[i] = (i as Field) * 20_000;
    }
    biases
}

// ============================================================================
// Pure test helper functions (no contract deployment required)
// ============================================================================

/// Compute forward pass using pure function (no storage access)
pub unconstrained fn compute_forward_pass_pure(
    input: [Field; 64],
    weights: [Field; 1184],
    biases: [Field; 26],
) -> [Field; 10] {
    let network_weights = arch_64_16_10::NetworkWeights { weights, biases };
    arch_64_16_10::compute_forward_pass(input, network_weights)
}

/// Compute confidence from logits (pure function)
pub unconstrained fn compute_confidence_pure(logits: [Field; 10]) -> (Field, Field) {
    let (exp_outputs, sum_exp_safe, _probabilities) = softmax::softmax_with_exp(logits);
    let max_index = softmax::argmax(logits);
    let confidence = softmax::compute_confidence(exp_outputs, sum_exp_safe, max_index);

    let prediction = max_index as Field;
    (prediction, confidence)
}

/// Compute full prediction (forward pass + softmax + confidence) without storage
pub unconstrained fn compute_prediction_pure(
    input: [Field; 64],
    weights: [Field; 1184],
    biases: [Field; 26],
) -> (Field, Field, [Field; 10]) {
    let logits = compute_forward_pass_pure(input, weights, biases);
    let probabilities = softmax::softmax(logits);
    let (prediction, confidence) = compute_confidence_pure(logits);
    (prediction, confidence, probabilities)
}
