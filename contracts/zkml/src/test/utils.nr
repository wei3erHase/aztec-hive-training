use crate::{architectures::arch_64_16_10, softmax};

// Architecture: 2-layer (64 -> 16 -> 10)
// Layer 1: 64*16 = 1024 weights, 16 biases
// Layer 2: 16*10 = 160 weights, 10 biases
// Total: 1184 weights, 26 biases

/// Helper function to create test weights array (1184 weights for 2-layer network)
pub unconstrained fn create_test_weights() -> [Field; 1184] {
    let mut weights: [Field; 1184] = [0; 1184];
    // Initialize with simple pattern for testing
    for i in 0..1184 {
        weights[i] = (i as Field) * 100;
    }
    weights
}

